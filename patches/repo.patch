+# -----------------------------------------------------------------------------
+# MPS-compatible RoPE: torch.view_as_complex is unsupported on MPS, so we
+# provide a real-math equivalent. Original complex path is preserved for
+# CUDA/CPU (bit-identical math via torch.view_as_complex).
+# -----------------------------------------------------------------------------
+_USE_REAL_ROPE = (
+    os.environ.get("SANA_WM_FORCE_PURE_PYTORCH", "0") == "1"
+    or os.environ.get("SANA_WM_NO_COMPLEX_ROPE", "0") == "1"
+)
+
+
+def _rope_use_real(hidden_states: torch.Tensor) -> bool:
+    """Decide whether to use the real-valued RoPE path."""
+    return _USE_REAL_ROPE or hidden_states.device.type == "mps"
+
+
+def _apply_rotary_emb_real_perm(hidden_states: torch.Tensor, freqs: torch.Tensor) -> torch.Tensor:
+    """Real-valued RoPE for tensors shaped (B, h, h_d, N).
+
+    Mirrors the original ``permute(0,1,3,2) -> view_as_complex -> *freqs -> view_as_real
+    -> flatten(3,4) -> permute(0,1,3,2)`` pipeline using cos/sin math.
+    """
+    x = hidden_states.permute(0, 1, 3, 2).to(torch.float32).unflatten(3, (-1, 2))
+    x_re = x[..., 0]
+    x_im = x[..., 1]
+    if freqs.is_complex():
+        f_cos = freqs.real.to(x_re.dtype)
+        f_sin = freqs.imag.to(x_re.dtype)
+    else:
+        f_cos = freqs[..., 0].to(x_re.dtype)
+        f_sin = freqs[..., 1].to(x_re.dtype)
+    o_re = x_re * f_cos - x_im * f_sin
+    o_im = x_re * f_sin + x_im * f_cos
+    out = torch.stack([o_re, o_im], dim=-1).flatten(3, 4).permute(0, 1, 3, 2)
+    return out.type_as(hidden_states)
+
+
+def _apply_rotary_emb_real_transpose(hidden_states: torch.Tensor, freqs: torch.Tensor) -> torch.Tensor:
+    """Real-valued RoPE for tensors shaped (B, N, h, h_d).
+
+    Mirrors ``transpose(1,2) -> view_as_complex -> *freqs -> view_as_real
+    -> flatten(3,4) -> transpose(1,2)`` pipeline.
+    """
+    x = hidden_states.transpose(1, 2).to(torch.float32).unflatten(3, (-1, 2))
+    x_re = x[..., 0]
+    x_im = x[..., 1]
+    if freqs.is_complex():
+        f_cos = freqs.real.to(x_re.dtype)
+        f_sin = freqs.imag.to(x_re.dtype)
+    else:
+        f_cos = freqs[..., 0].to(x_re.dtype)
+        f_sin = freqs[..., 1].to(x_re.dtype)
+    o_re = x_re * f_cos - x_im * f_sin
+    o_im = x_re * f_sin + x_im * f_cos
+    out = torch.stack([o_re, o_im], dim=-1).flatten(3, 4).transpose(1, 2)
+    return out.type_as(hidden_states)
+
+
+def _apply_rotary_emb_real_lumina(x: torch.Tensor, freqs_cis: torch.Tensor) -> torch.Tensor:
+    """Real-valued RoPE for the lumina-style path (line ~1580).
+
+    Mirrors:
+        x_rotated = view_as_complex(x.float().reshape(*x.shape[:-1], -1, 2))
+        freqs_cis = freqs_cis.unsqueeze(2)
+        x_out = view_as_real(x_rotated * freqs_cis).flatten(3)
+    """
+    x_pairs = x.float().reshape(*x.shape[:-1], -1, 2)
+    x_re = x_pairs[..., 0]
+    x_im = x_pairs[..., 1]
+    f = freqs_cis.unsqueeze(2)
+    if f.is_complex():
+        f_cos = f.real.to(x_re.dtype)
+        f_sin = f.imag.to(x_re.dtype)
+    else:
+        f_cos = f[..., 0].to(x_re.dtype)
+        f_sin = f[..., 1].to(x_re.dtype)
+    o_re = x_re * f_cos - x_im * f_sin
+    o_im = x_re * f_sin + x_im * f_cos
+    out = torch.stack([o_re, o_im], dim=-1).flatten(3)
+    return out.type_as(x)
