+def _rope_apply_real_wan(x_slice: torch.Tensor, freqs_i: torch.Tensor, n: int) -> torch.Tensor:
+    """Real-valued equivalent of:
+        x_i = view_as_complex(x_slice.to(float64).reshape(seq_len, n, -1, 2))
+        x_i = view_as_real(x_i * freqs_i).flatten(2)
+    Used by ``rope_apply`` for MPS.
+    """
+    seq_len = x_slice.shape[0]
+    x_pairs = x_slice.to(torch.float32).reshape(seq_len, n, -1, 2)
+    x_re = x_pairs[..., 0]
+    x_im = x_pairs[..., 1]
+    if freqs_i.is_complex():
+        f_cos = freqs_i.real.to(x_re.dtype)
+        f_sin = freqs_i.imag.to(x_re.dtype)
+    else:
+        f_cos = freqs_i[..., 0].to(x_re.dtype)
+        f_sin = freqs_i[..., 1].to(x_re.dtype)
+    o_re = x_re * f_cos - x_im * f_sin
+    o_im = x_re * f_sin + x_im * f_cos
+    out = torch.stack([o_re, o_im], dim=-1).flatten(2)
+    return out
