+def _make_generator(device: torch.device, seed: int) -> tuple[torch.Generator, torch.device]:
+    """Return a (generator, generator_device) pair safe across cuda/mps/cpu.
+
+    MPS rejects device-bound generators for ``torch.randn`` in some torch
+    builds, so we transparently fall back to a CPU generator and let callers
+    move the produced tensor onto ``device``.
+    """
+    try:
+        gen = torch.Generator(device=device).manual_seed(int(seed))
+        return gen, device
+    except (RuntimeError, TypeError):
+        gen = torch.Generator().manual_seed(int(seed))
+        return gen, torch.device("cpu")
