diff --git a/diffusion/model/nets/_triton_stub.py b/diffusion/model/nets/_triton_stub.py
new file mode 100644
index 0000000..4045e19
--- /dev/null
+++ b/diffusion/model/nets/_triton_stub.py
@@ -0,0 +1,363 @@
+"""Sys-modules ``triton`` shim for CPU / Apple-Silicon (MPS) hosts.
+
+Several third-party deps (``fla``, ``dc_ae`` triton helpers, the Sana ``*_triton``
+companion modules) eagerly ``import triton`` at module load time. On platforms
+without a triton wheel (macOS / MPS / CPU-only), this would crash the entire
+import chain.
+
+This module provides ``install_triton_stub_if_missing`` which installs a no-op
+``triton`` / ``triton.language`` package into ``sys.modules``. Decorators
+(``@triton.jit``, ``@triton.autotune``) become no-ops; calling any kernel will
+either silently do nothing or fail later. The intent is that callers route
+around triton entirely via ``SANA_WM_FORCE_PURE_PYTORCH=1`` and
+``FLA_USE_PURE_PYTORCH=1``, so the kernels never execute.
+
+Idempotent — safe to call from multiple modules. Must run BEFORE any
+``import fla`` / ``import triton`` statement in the same process.
+"""
+
+from __future__ import annotations
+
+import sys
+import types
+
+
+def install_triton_stub_if_missing() -> bool:
+    """Inject a no-op triton shim into ``sys.modules`` if triton is unavailable.
+
+    Returns ``True`` if the stub was installed, ``False`` if real triton was
+    already available (or the stub was already installed).
+    """
+    if "triton" in sys.modules:
+        return False
+    try:
+        import triton  # noqa: F401
+
+        return False
+    except ImportError:
+        pass
+
+    def _decorator_noop(fn=None, **_kw):
+        if fn is None:
+            def _wrap(f):
+                return f
+
+            return _wrap
+        return fn
+
+    def _next_power_of_2(n):
+        n = int(n)
+        p = 1
+        while p < n:
+            p <<= 1
+        return p
+
+    def _cdiv(a, b):
+        return -(-int(a) // int(b))
+
+    class _ConfigStub:
+        def __init__(self, *_a, **_kw):
+            pass
+
+    class _JITFunctionStub:
+        pass
+
+    class _Anything2:
+        def __init__(self, *_a, **_kw):
+            pass
+
+        def __class_getitem__(cls, item):
+            return cls
+
+        def __getattr__(self, name):
+            return _Anything2
+
+        def __call__(self, *a, **kw):
+            return None
+
+    triton_mod = types.ModuleType("triton")
+    triton_mod.__version__ = "0.0.0+stub"
+
+    def _triton_getattr(name):
+        if name.startswith("__") and name.endswith("__"):
+            raise AttributeError(name)
+        return _Anything2
+
+    triton_mod.__getattr__ = _triton_getattr  # type: ignore[attr-defined]
+    triton_mod.jit = _decorator_noop
+    triton_mod.autotune = lambda *_a, **_kw: (lambda fn: fn)
+    triton_mod.heuristics = lambda *_a, **_kw: (lambda fn: fn)
+    triton_mod.next_power_of_2 = _next_power_of_2
+    triton_mod.cdiv = _cdiv
+    triton_mod.Config = _ConfigStub
+    triton_mod.JITFunction = _JITFunctionStub
+
+    # Catch-all: every triton.language.<name> resolves to a no-op so unknown
+    # attribute lookups (e.g. ``tl.dtype``, ``tl.tensor``) don't crash torch's
+    # inductor module-level type annotations.
+    class _Anything:
+        def __init__(self, *_a, **_kw):
+            pass
+
+        def __class_getitem__(cls, item):
+            return cls
+
+        def __getattr__(self, name):
+            return _Anything
+
+        def __call__(self, *a, **kw):
+            return None
+
+    lang_mod = types.ModuleType("triton.language")
+
+    def _lang_getattr(name):
+        if name.startswith("__") and name.endswith("__"):
+            raise AttributeError(name)
+        return _Anything
+
+    lang_mod.__getattr__ = _lang_getattr  # type: ignore[attr-defined]
+
+    class _Constexpr:
+        """Stand-in for ``tl.constexpr`` — works as both an annotation and a
+        wrapper. ``tl.constexpr(value)`` returns the value unchanged."""
+
+        def __init__(self, value=None):
+            self.value = value
+
+        def __class_getitem__(cls, item):
+            return cls
+
+        def __new__(cls, value=None):
+            if value is None:
+                return object.__new__(cls)
+            return value  # passthrough wrap
+
+    lang_mod.constexpr = _Constexpr
+    lang_mod.float32 = "float32"
+    lang_mod.float16 = "float16"
+    lang_mod.bfloat16 = "bfloat16"
+    lang_mod.int32 = "int32"
+    lang_mod.int64 = "int64"
+
+    def _noop(*_a, **_kw):
+        return None
+
+    for name in (
+        "program_id",
+        "load",
+        "store",
+        "arange",
+        "zeros",
+        "dot",
+        "where",
+        "exp",
+        "log",
+        "sqrt",
+        "rsqrt",
+        "sigmoid",
+        "tanh",
+        "abs",
+        "floor",
+        "ceil",
+        "trans",
+        "minimum",
+        "maximum",
+        "sum",
+        "max",
+        "min",
+        "advance",
+        "make_block_ptr",
+        "atomic_add",
+        "atomic_max",
+        "static_assert",
+        "static_print",
+        "debug_barrier",
+        "tensor",
+        "device_print",
+        "broadcast_to",
+        "cdiv",
+        "full",
+        "view",
+        "reshape",
+        "cast",
+    ):
+        setattr(lang_mod, name, _noop)
+    triton_mod.language = lang_mod
+
+    # Mark triton / triton.language / triton.runtime as packages so attribute
+    # access like ``triton.language.extra.libdevice`` works.
+    triton_mod.__path__ = []  # type: ignore[attr-defined]
+    lang_mod.__path__ = []  # type: ignore[attr-defined]
+
+    # triton.language.extra.{libdevice, cuda.libdevice}
+    extra_mod = types.ModuleType("triton.language.extra")
+    extra_mod.__path__ = []  # type: ignore[attr-defined]
+    libdevice_mod = types.ModuleType("triton.language.extra.libdevice")
+    for name in ("exp", "log", "log2", "exp2", "rsqrt", "sqrt", "tanh", "sigmoid",
+                 "pow", "fast_expf", "fast_logf", "rcp", "floor", "ceil"):
+        setattr(libdevice_mod, name, _noop)
+    extra_mod.libdevice = libdevice_mod
+    extra_cuda_mod = types.ModuleType("triton.language.extra.cuda")
+    extra_cuda_mod.__path__ = []  # type: ignore[attr-defined]
+    extra_cuda_libdevice_mod = types.ModuleType("triton.language.extra.cuda.libdevice")
+    for name in ("exp", "log", "log2", "exp2", "rsqrt", "sqrt", "tanh", "sigmoid",
+                 "pow", "fast_expf", "fast_logf", "rcp", "floor", "ceil"):
+        setattr(extra_cuda_libdevice_mod, name, _noop)
+    extra_cuda_mod.libdevice = extra_cuda_libdevice_mod
+    extra_mod.cuda = extra_cuda_mod
+    lang_mod.extra = extra_mod
+    # triton.language.math
+    math_mod = types.ModuleType("triton.language.math")
+    for name in ("exp", "log", "log2", "exp2", "rsqrt", "sqrt", "tanh", "sigmoid", "pow"):
+        setattr(math_mod, name, _noop)
+    lang_mod.math = math_mod
+
+    # triton.runtime / triton.runtime.jit / triton.runtime.autotuner
+    runtime_mod = types.ModuleType("triton.runtime")
+    runtime_mod.__path__ = []  # type: ignore[attr-defined]
+    runtime_jit_mod = types.ModuleType("triton.runtime.jit")
+    runtime_jit_mod.JITFunction = _JITFunctionStub
+
+    class _KernelInterfaceStub:
+        def __init__(self, *_a, **_kw):
+            pass
+
+        def __getitem__(self, _key):
+            def _call(*_a, **_kw):
+                return None
+
+            return _call
+
+    runtime_jit_mod.KernelInterface = _KernelInterfaceStub
+    runtime_mod.jit = runtime_jit_mod
+
+    runtime_autotuner_mod = types.ModuleType("triton.runtime.autotuner")
+
+    class _OutOfResources(Exception):
+        pass
+
+    class _PTXASError(Exception):
+        pass
+
+    runtime_autotuner_mod.OutOfResources = _OutOfResources
+    runtime_autotuner_mod.PTXASError = _PTXASError
+    runtime_mod.autotuner = runtime_autotuner_mod
+
+    triton_mod.runtime = runtime_mod
+
+    # triton.compiler / triton.compiler.compiler
+    compiler_mod = types.ModuleType("triton.compiler")
+    compiler_mod.__path__ = []  # type: ignore[attr-defined]
+
+    class _CompiledKernel:
+        pass
+
+    compiler_mod.CompiledKernel = _CompiledKernel
+    compiler_compiler_mod = types.ModuleType("triton.compiler.compiler")
+
+    class _ASTSource:
+        pass
+
+    compiler_compiler_mod.ASTSource = _ASTSource
+
+    def _triton_key():
+        return "stub"
+
+    compiler_compiler_mod.triton_key = _triton_key
+    compiler_mod.compiler = compiler_compiler_mod
+    triton_mod.compiler = compiler_mod
+
+    # triton.language.standard._log2 and triton.language.core.view
+    lang_standard_mod = types.ModuleType("triton.language.standard")
+
+    def _stub_log2(x):
+        raise NotImplementedError
+
+    lang_standard_mod._log2 = _stub_log2
+    lang_mod.standard = lang_standard_mod
+    lang_core_mod = types.ModuleType("triton.language.core")
+    lang_core_mod.view = _noop
+    lang_mod.core = lang_core_mod
+
+    # triton.knobs / triton.runtime.cache.triton_key / triton.runtime.errors.IntelGPUError
+    knobs_mod = types.ModuleType("triton.knobs")
+    triton_mod.knobs = knobs_mod
+    runtime_cache_mod = types.ModuleType("triton.runtime.cache")
+    runtime_cache_mod.triton_key = _triton_key
+    runtime_mod.cache = runtime_cache_mod
+    runtime_errors_mod = types.ModuleType("triton.runtime.errors")
+
+    class _IntelGPUError(Exception):
+        pass
+
+    runtime_errors_mod.IntelGPUError = _IntelGPUError
+    runtime_mod.errors = runtime_errors_mod
+
+    # triton.backends.compiler.GPUTarget
+    backends_mod = types.ModuleType("triton.backends")
+    backends_mod.__path__ = []  # type: ignore[attr-defined]
+    backends_compiler_mod = types.ModuleType("triton.backends.compiler")
+
+    def _GPUTarget(backend, arch, warp_size):
+        return (backend, arch, warp_size)
+
+    backends_compiler_mod.GPUTarget = _GPUTarget
+    backends_mod.compiler = backends_compiler_mod
+    triton_mod.backends = backends_mod
+
+    _all_stub_mods = [
+        triton_mod,
+        lang_mod,
+        extra_mod,
+        libdevice_mod,
+        extra_cuda_mod,
+        extra_cuda_libdevice_mod,
+        math_mod,
+        lang_standard_mod,
+        lang_core_mod,
+        runtime_mod,
+        runtime_jit_mod,
+        runtime_autotuner_mod,
+        runtime_cache_mod,
+        runtime_errors_mod,
+        knobs_mod,
+        compiler_mod,
+        compiler_compiler_mod,
+        backends_mod,
+        backends_compiler_mod,
+    ]
+
+    def _make_getattr(_mod_name):
+        def _getattr(name):
+            # Never fabricate dunder attributes — let AttributeError propagate
+            # so introspection tools (inspect.getfile, pickle, etc.) behave.
+            if name.startswith("__") and name.endswith("__"):
+                raise AttributeError(name)
+            return _Anything2
+
+        return _getattr
+
+    for _m in _all_stub_mods:
+        if not hasattr(_m, "__getattr__"):
+            _m.__getattr__ = _make_getattr(_m.__name__)  # type: ignore[attr-defined]
+
+    sys.modules["triton"] = triton_mod
+    sys.modules["triton.language"] = lang_mod
+    sys.modules["triton.language.extra"] = extra_mod
+    sys.modules["triton.language.extra.libdevice"] = libdevice_mod
+    sys.modules["triton.language.extra.cuda"] = extra_cuda_mod
+    sys.modules["triton.language.extra.cuda.libdevice"] = extra_cuda_libdevice_mod
+    sys.modules["triton.language.math"] = math_mod
+    sys.modules["triton.language.standard"] = lang_standard_mod
+    sys.modules["triton.language.core"] = lang_core_mod
+    sys.modules["triton.runtime"] = runtime_mod
+    sys.modules["triton.runtime.jit"] = runtime_jit_mod
+    sys.modules["triton.runtime.autotuner"] = runtime_autotuner_mod
+    sys.modules["triton.runtime.cache"] = runtime_cache_mod
+    sys.modules["triton.runtime.errors"] = runtime_errors_mod
+    sys.modules["triton.knobs"] = knobs_mod
+    sys.modules["triton.compiler"] = compiler_mod
+    sys.modules["triton.compiler.compiler"] = compiler_compiler_mod
+    sys.modules["triton.backends"] = backends_mod
+    sys.modules["triton.backends.compiler"] = backends_compiler_mod
+    return True
